# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored — it never gets committed, so it's safe to put
# your real links/keys in it. This file (.env.example) stays in git as
# a template with placeholder values only.

# ----------------------------------------------------------------------
# SITE
# ----------------------------------------------------------------------
# Your deployed site's URL, no trailing slash. Used for canonical links,
# Open Graph tags, JSON-LD, sitemap.xml, and robots.txt.
VITE_SITE_URL=https://your-domain.com

# ----------------------------------------------------------------------
# PERSONAL DETAILS
# ----------------------------------------------------------------------
VITE_NAME=Mohd Altamish
VITE_TITLE=Full Stack Developer
VITE_SUBTITLE=MERN Stack
VITE_LOCATION=Amroha, Uttar Pradesh, India

VITE_PHONE=+91 9012556462
VITE_EMAIL=altamashsiddiqui941@gmail.com
# Digits only, with country code, no + or spaces (e.g. 919012556462).
# Leave blank to hide the WhatsApp button/link.
VITE_WHATSAPP_NUMBER=919012556462

# ----------------------------------------------------------------------
# SOCIAL LINKS
# ----------------------------------------------------------------------
VITE_GITHUB_URL=https://github.com/altamash-siddiquiii
VITE_LINKEDIN_URL=https://www.linkedin.com/in/altamash-siddiquiii
VITE_TWITTER_URL=
VITE_INSTAGRAM_URL=

# ----------------------------------------------------------------------
# EMAILJS (Contact form) — get these from https://emailjs.com after
# creating a free account, an email service, and a template.
# Only the PUBLIC key goes here — never a private/secret key.
# ----------------------------------------------------------------------
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
